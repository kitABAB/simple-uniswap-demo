# 复制本文件为 .env 并填入真实值（.env 不会被提交到 git）

# 部署用钱包私钥（测试网专用，切勿使用主网大额钱包！不要加 0x 前缀也可，ethers 会自动处理）
PRIVATE_KEY=

# Sepolia 测试网 RPC（可在 Alchemy / Infura 免费申请）
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Etherscan API Key（用于开源验证合约）
ETHERSCAN_API_KEY=

# 是否在测试时输出 gas 报告
REPORT_GAS=false
